#: data/org.mate.NotificationDaemon.gschema.xml.in:26
msgid "Turns on and off sound support for notifications."
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:30
msgid "Do not disturb"
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:31
msgid "When enabled, notifications are not shown."
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:36
msgid "Default timeout"
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:37
#: src/capplet/mate-notification-properties.ui:304
msgid ""
"Default timeout for notifications in milliseconds. Use 0 for no timeout "
"(persistent)."
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:41
msgid "Enable persistence"
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:42
msgid "Allow notifications to be persistent when requested by applications."
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:46
msgid "Show countdown"
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:47
msgid ""
"Show countdown timer for all non-persistent notifications. If false, only "
"show it for those waiting for user actions."
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:51
msgid "Enable notification history"
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:52
msgid ""
"When enabled, notifications are stored in history for later viewing. When "
"disabled, no notification history is kept for privacy. Note: This only "
"controls MATE's notification daemon storage; other applications may still "
"have access to notifications through system logs or other means."
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:56
msgid "Force display all notifications"
msgstr ""

#: data/org.mate.NotificationDaemon.gschema.xml.in:57
msgid ""
"When enabled, all notifications are shown regardless of urgency, fullscreen, "
"or screensaver state. Do Not Disturb still takes precedence."
msgstr ""

